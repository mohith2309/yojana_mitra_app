# BharatMitra backend environment template.
# Copy this file to backend/.env and fill only the services you want to test.
# Keep real secrets only in backend/.env. Never commit real keys.

# ---------------------------------------------------------------------------
# NVIDIA AI
# ---------------------------------------------------------------------------
# Required for:
# - POST /nvidia/chat
# - POST /nvidia/pii-detect
# - POST /nvidia/rerank
# Leave blank to make those endpoints return HTTP 503 while local app behavior
# continues to work.
NVIDIA_API_KEY=

# OpenAI-compatible NVIDIA chat completions base URL.
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Model routing for /nvidia/chat.
NVIDIA_CONSUMER_MODEL=google/gemma-3n-e4b-it
NVIDIA_AUTOTASK_MODEL=mistralai/mistral-medium-3.5-128b
NVIDIA_REASONING_MODEL=mistralai/mistral-medium-3.5-128b
NVIDIA_FALLBACK_MODEL=mistralai/mistral-large-3-675b-instruct-2512
NVIDIA_SAFETY_MODEL=meta/llama-guard-4-12b
NVIDIA_SMALL_MODEL=nvidia/nemotron-mini-4b-instruct
NVIDIA_MULTIMODAL_MODEL=microsoft/phi-4-multimodal-instruct
NVIDIA_EMBED_MODEL=nvidia/llama-3_2-nemoretriever-300m-embed-v1
NVIDIA_VISION_MODEL=google/paligemma

# NVIDIA retrieval reranking endpoint used by POST /nvidia/rerank.
NVIDIA_RERANK_MODEL=nv-rerank-qa-mistral-4b:1
NVIDIA_RERANK_URL=https://ai.api.nvidia.com/v1/retrieval/nvidia/reranking

# NVIDIA GLINER model used by POST /nvidia/pii-detect.
NVIDIA_PII_MODEL=nvidia/gliner-pii

# Future voice/audio models. These are documented for planning; current routes
# do not call them yet.
NVIDIA_TTS_MODEL=nvidia/magpie-tts-zeroshot
NVIDIA_AUDIO_ENHANCE_MODEL=nvidia/studiovoice

# Chat generation defaults for non-consumer modes.
NVIDIA_ENABLE_THINKING=true
NVIDIA_CLEAR_THINKING=false
NVIDIA_TEMPERATURE=0.7
NVIDIA_TOP_P=1
NVIDIA_MAX_TOKENS=16384
NVIDIA_REASONING_EFFORT=high

# Chat generation defaults for consumer mode.
NVIDIA_CONSUMER_TEMPERATURE=0.2
NVIDIA_CONSUMER_TOP_P=0.7
NVIDIA_CONSUMER_MAX_TOKENS=512

# Safety mode defaults.
NVIDIA_SAFETY_TEMPERATURE=1.0
NVIDIA_SAFETY_TOP_P=0.7
NVIDIA_SAFETY_MAX_TOKENS=30

# Small/cheap mode defaults.
NVIDIA_SMALL_TEMPERATURE=0.2
NVIDIA_SMALL_TOP_P=0.7
NVIDIA_SMALL_MAX_TOKENS=1024

# Multimodal mode defaults.
NVIDIA_MULTIMODAL_TEMPERATURE=0.1
NVIDIA_MULTIMODAL_TOP_P=0.7
NVIDIA_MULTIMODAL_MAX_TOKENS=512

# ---------------------------------------------------------------------------
# data.gov.in
# ---------------------------------------------------------------------------
# Required for live data.gov.in fetches and GET /data-gov/resource/{resource_id}.
# Leave blank to return local_fallback from service endpoints or HTTP 503 from
# /data-gov/resource/{resource_id}.
DATA_GOV_API_KEY=
DATA_GOV_BASE_URL=https://api.data.gov.in

# Mandi price advisor: POST /mandi/advice.
MANDI_DATA_GOV_RESOURCE_ID=9ef84268-d588-465a-a308-a864a43d0070
MANDI_FEED_URL=

# AQI activity planner: POST /aqi/plan.
AQI_DATA_GOV_RESOURCE_ID=3b01bcb8-0b14-4abf-b6f2-c1bfd384ba69
AQI_FEED_URL=

# Flood/disaster risk: POST /flood/risk.
FLOOD_DATA_GOV_RESOURCE_ID=6c05cd1b-ed59-40c2-bc31-e314f39c6971
FLOOD_RAINFALL_YEAR=2025
SOIL_MOISTURE_DATA_GOV_RESOURCE_ID=4554a3c8-74e3-4f93-8727-8fd92161e345
SOIL_MOISTURE_YEAR=2022
SOIL_MOISTURE_MONTH=01
FLOOD_ALERT_FEED_URL=

# Career guide: POST /career/guide.
SCHOLARSHIP_DATA_GOV_RESOURCE_ID=
SCHOLARSHIP_FEED_URL=
SKILL_DATA_GOV_RESOURCE_ID=
SKILL_FEED_URL=

# Civic report helper: POST /civic/report-draft.
CIVIC_DIRECTORY_DATA_GOV_RESOURCE_ID=71818d1a-c114-46cb-aa9b-56ed70d4bc4a
CIVIC_DIRECTORY_BACKUP_DATA_GOV_RESOURCE_ID=1a6c26ed-d67c-40ea-aa20-d38d35f341a5
LGD_VILLAGES_DATA_GOV_RESOURCE_ID=c967fe8f-69c4-42df-8afc-8a2c98057437
LGD_VILLAGES_PIN_DATA_GOV_RESOURCE_ID=f17a1608-5f10-4610-bb50-a63c80d83974
CIVIC_DIRECTORY_FEED_URL=

# ---------------------------------------------------------------------------
# Bhashini / Dhruva
# ---------------------------------------------------------------------------
# Required for POST /bhashini/asr-placeholder. Current route is a placeholder
# until a real pipeline task sequence is added.
BHASHINI_API_KEY=
BHASHINI_USER_ID=
BHASHINI_PIPELINE_ID=
BHASHINI_BASE_URL=https://dhruva-api.bhashini.gov.in

# ---------------------------------------------------------------------------
# API Setu / DigiLocker
# ---------------------------------------------------------------------------
# Reserved for a future real DigiLocker consent flow. Current app/backend uses
# POST /digilocker/mock-documents, which does not require these values.
API_SETU_CLIENT_ID=
API_SETU_CLIENT_SECRET=
API_SETU_BASE_URL=https://apisetu.gov.in
DIGILOCKER_REDIRECT_URI=http://localhost:8000/digilocker/callback
